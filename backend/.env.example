# Global Fishing Watch — Events API v3 bearer token.
# Create one at https://globalfishingwatch.org/our-apis/
GFW_TOKEN=

# Persistent storage for the ocean pool mask + SQLite DB + daily PDFs.
# On Railway, mount a volume here.
DATA_DIR=./data

# Project "day 1" — used to render the DAY counter on the frontend.
HAVOC_DAY_0=2026-02-13

# Daily depletion job — fires at this UTC time (GFW publishes around midday).
HAVOC_SCHEDULE_HOUR_UTC=14
HAVOC_SCHEDULE_MINUTE_UTC=15

# Optional fallback — path to a saved GFW dump (events_*.json) used if the
# live API fails. Leave empty to disable.
HAVOC_FALLBACK_JSON=

LOG_LEVEL=INFO
